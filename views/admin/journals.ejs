<div class="container py-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Manage Journals</h1>
    <a href="/admin/journals/new" class="btn btn-primary">+ Upload Journal</a>
  </div>

  <% if (success_msg.length > 0) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>

  <% if (error_msg.length > 0) { %>
    <div class="alert alert-danger"><%= error_msg %></div>
  <% } %>

  <% if (journals.length === 0) { %>
    <div class="alert alert-info">No journals uploaded yet.</div>
  <% } %>

  <div class="row">
    <% journals.forEach(journal => { %>

      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">

          <div class="card-body ">
            <h5 class="card-title mb-3"><%= journal.title %></h5>

            <p class="card-text mb-1">
              <strong>Author:</strong> <%= journal.author %>
            </p>

            <p class="card-text">
              <strong>Category:</strong> <%= journal.category_name || 'Uncategorized' %>
            </p>

            <p class="card-text">
              <strong>Year:</strong> <%= journal.year %>
            </p>

            <span class="badge bg-<%= journal.access_type === 'premium' ? 'danger' : 'success' %>">
              <%= journal.access_type.toUpperCase() %>
            </span>
          </div>

         <div class="card-footer bg-white text-center">

  <!-- View button -->
  <a href="/journals/<%= journal.id %>" target="_blank" 
     class="btn btn-outline-primary btn-sm mb-2 w-100">
    View
  </a>

  <!-- Edit + Delete row -->
  <div class="d-flex justify-content-between">

    <a href="/admin/journals/<%= journal.id %>/edit" 
       class="btn btn-warning btn-sm w-50 me-1">
      Edit
    </a>

    <form action="/admin/journals/<%= journal.id %>/delete" method="POST" class="w-50 ms-1">
      <button type="submit" 
        class="btn btn-danger btn-sm w-100"
        onclick="return confirm('Delete this journal?')">
        Delete
      </button>
    </form>

  </div>

</div>

        </div>
      </div>

    <% }) %>
  </div>

</div>