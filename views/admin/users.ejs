<div class="container py-5">

  <h1 class="mb-4">Manage Users</h1>

  <% if (success_msg && success_msg.length > 0) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>

  <% if (error_msg && error_msg.length > 0) { %>
    <div class="alert alert-danger"><%= error_msg %></div>
  <% } %>

  <div class="table-responsive">
    <table class="table table-bordered table-striped align-middle">

      <thead class="table-light">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Membership</th>
          <th>Role</th>
        </tr>
      </thead>

      <tbody>
        <% users.forEach(user => { %>
          <tr>

            <td><%= user.full_name %></td>
            <td><%= user.email %></td>

            <!-- MEMBERSHIP -->
            <td>
              <form action="/admin/users/membership" method="POST">
                <input type="hidden" name="userId" value="<%= user.id %>">

                <select name="membership" class="form-select" onchange="this.form.submit()">
                  <option value="free" <%= user.membership_type === 'free' ? 'selected' : '' %>>
                    Free
                  </option>

                  <option value="premium" <%= user.membership_type === 'premium' ? 'selected' : '' %>>
                    Premium
                  </option>
                </select>
              </form>
            </td>

            <!-- ROLE -->
            <td>
              <form action="/admin/users/role" method="POST">
                <input type="hidden" name="userId" value="<%= user.id %>">

                <select name="role" class="form-select" onchange="this.form.submit()">
                  <option value="member" <%= user.role === 'member' ? 'selected' : '' %>>
                    Member
                  </option>

                  <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>
                    Admin
                  </option>
                </select>
              </form>
            </td>

          </tr>
        <% }) %>
      </tbody>

    </table>
  </div>

</div>