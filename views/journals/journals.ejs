<section style="padding: 40px;">
  <h1>Manage Journals</h1>

  <a href="/admin/journals/new">+ Upload New Journal</a>

  <hr>

  <% if (journals.length === 0) { %>
    <p>No journals uploaded yet.</p>
  <% } %>

  <% journals.forEach(journal => { %>
    <div style="border:1px solid #ddd; padding:15px; margin-bottom:15px;">
      <h3><%= journal.title %></h3>
      <p><strong>Author:</strong> <%= journal.author %></p>
      <p><strong>Category:</strong> <%= journal.category_name || 'Uncategorized' %></p>
      <p><strong>Access:</strong> <%= journal.access_type %></p>
      <p><strong>Year:</strong> <%= journal.year %></p>
      <a href="/journals/<%= journal.id %>" target="_blank">View</a>
    </div>
    <div style="margin-top:10px;">
  <a href="/admin/journals/<%= journal.id %>/edit" class="btn btn-sm btn-warning">Edit</a>

  <form action="/admin/journals/<%= journal.id %>/delete" method="POST" style="display:inline;">
    <button type="submit" class="btn btn-sm btn-danger"
      onclick="return confirm('Are you sure you want to delete this journal?')">
      Delete
    </button>
  </form>
</div>
  <% }) %>
</section>