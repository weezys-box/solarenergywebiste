<div class="container py-5">

  <h1 class="mb-4">Dashboard</h1>

  <div class="card p-4 shadow-sm">

    <h4 class="mb-3">Welcome, <%= user.full_name %></h4>

    <hr>

    <h5 class="mb-3 text-success">Membership Information</h5>

    <p>
      <strong>Category:</strong> 
      <%= user.membership_category || 'Not Selected' %>
    </p>

    <p>
      <strong>Status:</strong> 
      <span class="badge bg-<%= user.membership_status === 'active' ? 'success' : 'danger' %>">
        <%= user.membership_status || 'inactive' %>
      </span>
    </p>

    <p>
      <strong>Expiry Date:</strong> 
      <%= user.membership_expiry 
          ? new Date(user.membership_expiry).toDateString() 
          : 'N/A' %>
    </p>

    <hr>

    <!-- ACTION BUTTON -->
   <hr>

<h5 class="mb-3 text-success">Application Status</h5>

<% if (user.application_status === 'pending') { %>

  <div class="alert alert-warning">
    Your application is under review. You will be notified once approved.
  </div>

<% } else if (user.application_status === 'rejected') { %>

  <div class="alert alert-danger">
    Your application was not approved. Please contact admin.
  </div>

<% } else if (user.application_status === 'approved' && user.payment_status === 'unpaid') { %>

  <div class="alert alert-info">
    Your application has been approved. Please complete your payment to activate your membership.
  </div>

  <a href="/membership/pay" class="btn btn-success">
    Pay Membership Fee
  </a>

<% } else if (user.membership_status === 'active') { %>

  <div class="alert alert-success mt-3">
    Your membership is active
  </div>

<% } %>
  </div>

</div>