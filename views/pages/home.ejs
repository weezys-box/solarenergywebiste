<!-- =========================
     MODERN HERO SECTION
========================= -->

<section class="modern-hero">

  <!-- BACKGROUND -->
  <div class="hero-bg"></div>

  <!-- OVERLAY -->
  <div class="hero-overlay"></div>

  <div class="container hero-grid">

    <!-- LEFT CONTENT -->
    <div class="hero-left">

      <div class="hero-badge">
        ADVANCING RENEWABLE ENERGY SINCE 1984
      </div>

      <h1>
        Advancing <br>
        Solar Innovation <br>
        <span>Across Nigeria</span>
      </h1>

      <p>
        Driving research, advocacy, capacity building
        and sustainable energy transformation for
        a cleaner and greener Nigeria.
      </p>

      <div class="hero-buttons">

        <a href="/register" class="hero-btn primary-btn">
          Become a Member
        </a>

        <a href="/about" class="hero-btn secondary-btn">
          Learn More
        </a>

      </div>

    </div>

    <!-- RIGHT VISUAL -->
    <div class="hero-right">

      <!-- GLOW -->
      <div class="hero-glow"></div>

      <!-- MAIN IMAGE -->
      <img src="/images/engineer.png"
           alt="Renewable Energy Professional"
           class="hero-person">

      <!-- FLOATING CARDS -->

      <div class="floating-card card-1">
        <h3>500+</h3>
        <p>Energy Professionals</p>
      </div>

      <div class="floating-card card-2">
        <h3>100+</h3>
        <p>Research Publications</p>
      </div>

      <div class="floating-card card-3">
        <h3>40+</h3>
        <p>Years of Renewable Impact</p>
      </div>

      <div class="floating-card card-4">
        <h3>NASEF</h3>
        <p>National Solar Energy Forum</p>
      </div>

    </div>

  </div>

</section>

<!-- =========================
     FLOATING STATS BAR
========================= -->

<section class="hero-stats">

  <div class="container">

    <div class="stats-wrapper">

      <div class="stat-item">
        <div class="stat-icon">🌍</div>
        <h4>Nationwide Impact</h4>
        <p>Across all 36 states & FCT</p>
      </div>

      <div class="stat-item">
        <div class="stat-icon">🎓</div>
        <h4>Capacity Building</h4>
        <p>Training future energy leaders</p>
      </div>

      <div class="stat-item">
        <div class="stat-icon">🤝</div>
        <h4>Strong Partnerships</h4>
        <p>Collaborating locally & globally</p>
      </div>

      <div class="stat-item">
        <div class="stat-icon">🌱</div>
        <h4>Sustainable Future</h4>
        <p>Promoting affordable clean energy</p>
      </div>

    </div>

  </div>

</section>

<!-- =========================
     WHO WE ARE
========================= -->

<section class="section bg-white">

  <div class="container">

    <div class="row align-items-center g-5">

      <div class="col-lg-6">

        <img src="/images/banner3.jpg"
             class="img-fluid rounded-4 shadow-lg"
             alt="Solar Energy">

      </div>

      <div class="col-lg-6">

        <div class="section-tag">
          WHO WE ARE
        </div>

        <h2 class="section-title">
          Driving Renewable Energy Innovation in Nigeria
        </h2>

        <p class="section-text">
          The Solar Energy Society of Nigeria (SESN) is a professional
          body committed to advancing renewable energy research,
          advocacy, collaboration and sustainable development
          across Nigeria.
        </p>

        <p class="section-text">
          Through conferences, publications, training programs
          and strategic partnerships, SESN continues to support
          the transition towards cleaner and more reliable
          energy systems.
        </p>

        <a href="/about" class="btn btn-success px-4 py-3 mt-3">
          Learn More
        </a>

      </div>

    </div>

  </div>

</section>

<!-- =========================
     INITIATIVES PREVIEW
========================= -->

<section class="section initiatives-section">

  <div class="container">

    <div class="text-center mb-5">

      <div class="section-tag mx-auto">
        OUR INITIATIVES
      </div>

      <h2 class="section-title">
        Transforming Communities Through Solar Energy
      </h2>

      <p class="section-text mx-auto">
        Empowering communities, institutions and professionals
        through impactful renewable energy programs.
      </p>

    </div>

    <div class="row g-4">

      <!-- CARD -->

      <div class="col-lg-4">

        <div class="initiative-card">

          <img src="/images/solar1.jpg"
               class="initiative-img"
               alt="Rural Electrification">

          <div class="initiative-content">

            <h4>Rural Electrification</h4>

            <p>
              Expanding clean energy access to underserved
              communities across Nigeria.
            </p>

            <a href="/rural-electrification">
              Learn More →
            </a>

          </div>

        </div>

      </div>

      <!-- CARD -->

      <div class="col-lg-4">

        <div class="initiative-card">

          <img src="/images/solar2.jpg"
               class="initiative-img"
               alt="Solar For Schools">

          <div class="initiative-content">

            <h4>Solar for Schools</h4>

            <p>
              Supporting education through sustainable
              and reliable solar-powered infrastructure.
            </p>

            <a href="/solar-schools">
              Learn More →
            </a>

          </div>

        </div>

      </div>

      <!-- CARD -->

      <div class="col-lg-4">

        <div class="initiative-card">

          <img src="/images/banner3.jpg"
               class="initiative-img"
               alt="Capacity Building">

          <div class="initiative-content">

            <h4>Capacity Building</h4>

            <p>
              Training researchers, students and professionals
              in renewable energy innovation.
            </p>

            <a href="/training">
              Learn More →
            </a>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<!-- =========================
     NEWS & EVENTS
========================= -->

<section class="section bg-white">

  <div class="container">

    <div class="text-center mb-5">

      <div class="section-tag mx-auto">
        NEWS & EVENTS
      </div>

      <h2 class="section-title">
        Latest Updates
      </h2>

    </div>

    <div class="row">

      <% if (news && news.length > 0) { %>

        <% news.forEach(item => { %>

          <div class="col-lg-4 mb-4">

            <a href="/news-events/<%= item.id %>"
               style="text-decoration: none; color: inherit;">

              <div class="news-card">

                <img src="<%= item.image || '/images/banner3.jpg' %>"
                     class="news-img"
                     alt="News">

                <div class="news-content">

                  <div class="news-date">
                    <%= item.created_at
                        ? new Date(item.created_at).toDateString()
                        : '' %>
                  </div>

                  <h4>
                    <%= item.title %>
                  </h4>

                  <p>
                    <%= item.content
                        ? item.content.substring(0, 100) + '...'
                        : '' %>
                  </p>

                </div>

              </div>

            </a>

          </div>

        <% }) %>

      <% } else { %>

        <p class="text-center text-muted">
          No news available yet.
        </p>

      <% } %>

    </div>

  </div>

</section>

<!-- =========================
     CTA SECTION
========================= -->

<section class="section cta-section">

  <div class="container text-center">

    <div class="cta-box">

      <h2>
        Become Part of Nigeria’s Renewable Energy Future
      </h2>

      <p>
        Join researchers, professionals and innovators
        driving sustainable energy transformation.
      </p>

      <a href="/register"
         class="hero-btn primary-btn mt-3">
        Join the Society
      </a>

    </div>

  </div>

</section>