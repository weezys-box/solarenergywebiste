<!-- HERO -->
<section class="section text-white text-center" style="background-color: var(--primary-green);">
  <div class="container">
    <h1 class="display-5 fw-bold">Membership</h1>
    <p class="lead mb-4" style="max-width: 700px; margin: 0 auto;">
      Become part of the Solar Energy Society of Nigeria (SESN) and contribute to sustainable energy development.
    </p>
  </div>
</section>

